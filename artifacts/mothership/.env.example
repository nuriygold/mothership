CRON_SECRET=
# Optional worker identity used when dispatch queue processing stamps a process owner. Consumed by artifacts/mothership/src/lib/services/dispatch.ts.
MOTHERSHIP_DISPATCH_WORKER_ID=
LOG_LEVEL=
APP_TIMEZONE=America/New_York
ENABLE_DISPATCH_RUNTIME=true
ENABLE_LEGACY_DISPATCH_INGRESS=false
ENABLE_LEGACY_DURABLE_OPS=false
ENABLE_MOCK_TOOL_ADAPTERS=false
ENABLE_VOLATILE_SYSTEM_RULES=false

# Task source defaults for the V2 tasks feed
