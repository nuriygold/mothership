# Canonical environment template for the current checked-in mothership and api-server source.
# Framework-provided reads that are not normally set in .env files: BASE_URL, NODE_ENV, REPL_ID.
# They are documented here for completeness, but they should come from the toolchain or runtime.

# Core runtime
# PORT is required by artifacts/api-server/src/index.ts. Vite also reads it, but falls back to 5000 if unset.
PORT=4100
API_BASE_URL=http://127.0.0.1:4100
BASE_PATH=/
LOG_LEVEL=info
APP_TIMEZONE=America/New_York
MOTHERSHIP_DISPATCH_WORKER_ID=
MOTHERSHIP_OPERATOR_NAME=
MOTHERSHIP_TASK_SOURCE=task_pool_repo
ENABLE_DISPATCH_RUNTIME=true
ENABLE_LEGACY_DISPATCH_INGRESS=false
ENABLE_LEGACY_DURABLE_OPS=false
ENABLE_MOCK_TOOL_ADAPTERS=false
ENABLE_VOLATILE_SYSTEM_RULES=false

# Persistence roots for derivative campaign exports and revenue-stream scans.
# Defaults stay backward-compatible when these are omitted.
DISPATCH_OUTPUT_ROOT=
DISPATCH_WORKSPACE_ROOT=
REVENUE_STREAMS_ROOT=

# Database. At least one must be set or runtime/drift checks fail fast.
SUPABASE_DATABASE_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=
DATABASE_MIGRATION_URL=
DATABASE_POOLER_URL=
DATABASE_URL_POOLER_TRANS=
DATABASE_URL_POOLER_SESSION=
DATABASE_URL=

# Dispatch and owner auth
# CRON_SECRET is required for dispatch worker auth.
# OWNER_PASSPHRASE is required for /v2/auth/login.
# OWNER_AUTH_SECRET signs owner cookies and falls back to CRON_SECRET if unset.
CRON_SECRET=
OWNER_PASSPHRASE=
OWNER_AUTH_SECRET=
MOTHERSHIP_V2_API_KEY=

# Task pool / GitHub
TASK_POOL_REPO_OWNER=nuriygold
TASK_POOL_REPO_NAME=task-pool
TASK_POOL_REPO_BRANCH=main
TASK_POOL_SNAPSHOT_PATH=data/task-pool-snapshot.json
GITHUB_TOKEN=

# OpenClaw / inference
# Dispatch runtime requires OPENCLAW_TOKEN plus one of OPENCLAW_INFERENCE_GATEWAY or OPENCLAW_GATEWAY.
OPENCLAW_INFERENCE_GATEWAY=
OPENCLAW_GATEWAY=
OPENCLAW_INFERENCE_PROVIDER=
OPENCLAW_TOKEN=
OPENCLAW_MODEL=
OPENCLAW_AGENT_ADRIAN=
OPENCLAW_AGENT_EMERALD=
OPENCLAW_AGENT_RUBY=
OPENCLAW_AGENT_ADOBE=
OPENCLAW_AGENT_ANCHOR=
OPENCLAW_AGENT_DISPATCH=
OPENCLAW_DEFAULT_AGENT=
# OPENCLAW_STREAMS_PATH falls back to ~/.openclaw/workspace/revenue_streams when unset.
OPENCLAW_STREAMS_PATH=
# Campaign queue documents mirror from the canonical OpenClaw queue folder by default.
OPENCLAW_CAMPAIGN_QUEUE_ROOT=
AZURE_OPENAI_API_VERSION=preview
OPENAI_API_VERSION=preview

# Teller and webhook forwarding
# If TELLER_ENV is set, TELLER_APPLICATION_ID and TELLER_ENCRYPTION_KEY become required.
# Non-sandbox Teller also requires TELLER_CERT_PEM and TELLER_KEY_PEM.
APP_URL=
NEXT_PUBLIC_APP_URL=
TELLER_APPLICATION_ID=
TELLER_ENCRYPTION_KEY=
TELLER_ENV=
TELLER_CERT_PEM=
TELLER_KEY_PEM=
TELLER_WEBHOOK_SECRET=
GATEWAY_HOOK_URL=
OPENCLAW_HOOKS_TOKEN=
TELLER_BRIDGE_LOG=
TELLER_BRIDGE_HOST=
TELLER_BRIDGE_PORT=

# Calendar and email
# Google Calendar and Gmail/Zoho features are conditional. Missing creds degrade those features, they do not boot-fail the server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
EMAIL_PROVIDER=gmail
EMAIL_INBOXES=
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_IMAP_USERNAME=
ZOHO_IMAP_PASSWORD=
ZOHO_EMAIL_USER=
ZOHO_EMAIL_PASS=
ZOHO_APP_PASSWORD=
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_SECURE=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_2=
TELEGRAM_BOT_TOKEN_3=
TELEGRAM_BOT_TOKEN_ADOBE=
TELEGRAM_CHAT_ID=
TELEGRAM_DEFAULT_BOT_KEY=bot2

# Misc integrations
SEARCH_API_KEY=
EBAY_APP_ID=
# Public bucket for generated vision assets. Keep public because the app serves public URLs.
SUPABASE_VISION_BUCKET=vision-images

# Client-side Vite env
VITE_TELLER_APPLICATION_ID=
VITE_TELLER_ENV=sandbox
