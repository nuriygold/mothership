{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npm run db:migrate && npm run build",
  "installCommand": "npm install --ignore-scripts",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/dispatch/worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v2/email/triage/worker",
      "schedule": "*/30 * * * *"
    }
  ]
}
