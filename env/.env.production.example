# Production Supabase connection string (service role) -- store in host secrets, never commit real values.
# Format: postgresql://postgres:<SERVICE_ROLE_PASSWORD>@<HOST>:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:YOUR_SERVICE_ROLE_PASSWORD@your-supabase-host.supabase.co:5432/postgres?schema=public"

# Notes:
# - Use a separate Supabase project/DB for production.
# - Client-side code should use the anon/public key; do not expose service-role in the browser.

# Task source configuration (Mothership task/workflow views read from GitHub task-pool by default).
MOTHERSHIP_TASK_SOURCE="task_pool_repo"
TASK_POOL_REPO_OWNER="nuriygold"
TASK_POOL_REPO_NAME="task-pool"
TASK_POOL_REPO_BRANCH="main"
TASK_POOL_SNAPSHOT_PATH="data/task-pool-snapshot.json"

