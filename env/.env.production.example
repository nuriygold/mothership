# Production Supabase connection string (service role) -- store in host secrets, never commit real values.
# Format: postgresql://postgres:<SERVICE_ROLE_PASSWORD>@<HOST>:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:YOUR_SERVICE_ROLE_PASSWORD@your-supabase-host.supabase.co:5432/postgres?schema=public"

# Notes:
# - Use a separate Supabase project/DB for production.
# - Client-side code should use the anon/public key; do not expose service-role in the browser.

# Task source configuration (Mothership task/workflow views read from GitHub task-pool by default).
MOTHERSHIP_TASK_SOURCE="task_pool_repo"
TASK_POOL_REPO_OWNER="nuriygold"
TASK_POOL_REPO_NAME="task-pool"
TASK_POOL_REPO_BRANCH="main"
TASK_POOL_SNAPSHOT_PATH="data/task-pool-snapshot.json"
# GitHub personal access token (classic or fine-grained) — required for task-pool repo read/write
GITHUB_TOKEN=""

# Email connector
# EMAIL_PROVIDER options: "gmail" | "zoho" | "both"
# Set to "both" to merge Gmail + Zoho feeds simultaneously (up to 50 emails each)
EMAIL_PROVIDER="gmail"
EMAIL_INBOXES="bashiraaliya@gmail.com,hello@nuriy.com"

# Gmail OAuth — token must include these scopes:
#   https://www.googleapis.com/auth/gmail.readonly
#   https://www.googleapis.com/auth/gmail.send
#   https://www.googleapis.com/auth/gmail.modify   (required for Delete / Trash)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# Zoho IMAP (read)
ZOHO_IMAP_HOST="imap.zoho.com"
ZOHO_IMAP_PORT="993"
ZOHO_IMAP_USERNAME=""
ZOHO_IMAP_PASSWORD=""

# Zoho SMTP (send) — if blank, falls back to ZOHO_IMAP_USERNAME / ZOHO_IMAP_PASSWORD
ZOHO_EMAIL_USER=""
ZOHO_EMAIL_PASS=""
ZOHO_SMTP_HOST="smtp.zoho.com"
ZOHO_SMTP_PORT="587"

# Calendar — token must include:
#   https://www.googleapis.com/auth/calendar.events  (required for Add to Calendar)
GOOGLE_CALENDAR_ID=""
GOOGLE_CALENDAR_ICAL_URL=""
# OPENCLAW_GATEWAY points to the OpenClaw Data Bridge (mother.nuriy.com).
# It is used for the /health check and as a fallback inference base.
OPENCLAW_GATEWAY="https://mother.nuriy.com"
OPENCLAW_TOKEN=""
# OPENCLAW_INFERENCE_GATEWAY points to the AI inference server that exposes
# POST /v1/responses.  Set this when the inference endpoint lives on a
# different host than the data bridge (e.g. your local Mac mini via Tailscale).
# If unset, OPENCLAW_GATEWAY is used for inference as well.
OPENCLAW_INFERENCE_GATEWAY=""

# Dispatch queue worker — protects /api/dispatch/worker (called by Vercel Cron every 5 min)
CRON_SECRET=""

# Tool-use integrations (optional — leave blank to use stubs)
SEARCH_API_KEY=""
EBAY_APP_ID=""

# Azure Speech (voice in/out)
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastus2"
AZURE_SPEECH_VOICE="en-US-AriaNeural"

# Telegram bots
# bot1 = Adrian, bot2 = Ruby, bot3 = Emerald (financial intelligence), botAdobe = Adobe
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_TOKEN_2=""
TELEGRAM_BOT_TOKEN_3=""
TELEGRAM_BOT_TOKEN_ADOBE=""
TELEGRAM_DEFAULT_BOT_KEY="bot2"
TELEGRAM_CHAT_ID=""

# Public base URL of the deployed app. Used to register the Plaid webhook URL
# on every linkTokenCreate call (e.g. https://claw.nuriy.com).
APP_URL=""

# Plaid — bank account linking
# PLAID_ENV options: "sandbox" | "development" | "production"
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
# 32-byte hex key for AES-256-GCM encryption of stored access tokens.
# Generate with: openssl rand -hex 32
PLAID_ENCRYPTION_KEY=""

# NOTE:
# This is a Next.js app (not Vite), so use these env names directly.
# Do not use VITE_* prefixes here.
